# Copy this file to .env and fill in. Vite only exposes vars prefixed with VITE_ to the client.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic (optional, for AI features). SERVER-SIDE ONLY — no VITE_ prefix.
# Used by /api/ai-chat and /api/ai-schedule serverless functions on Vercel.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for AI features.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
