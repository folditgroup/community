# ---- Frontend (Vite, exposed to the browser — anon key only) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Absolute URL of the usage-ingest endpoint shown in each bot's "Setup" panel.
# Leave unset to use the same-origin /api/webhook/usage that ships with this repo
# (Vercel). When you move to AWS, point this at your API Gateway / ALB URL —
# only this value changes, not the app code.
VITE_INGEST_URL=

# ---- Backend (Vercel serverless functions — never exposed to the client) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Shared secret that Node-RED must send in the webhook body to authenticate
WEBHOOK_SECRET=replace-with-a-long-random-string
